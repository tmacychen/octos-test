# Octos Test Configuration
# Copy this file to .env and fill in your values

# Path to octos binary (optional, auto-detected if not set)
# OCTOS_BINARY=/path/to/octos/target/release/octos

# Required for bot LLM tests
ANTHROPIC_API_KEY=your_api_key_here

# Required for Telegram bot tests (mock mode accepts any non-empty string)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional for Discord tests (mock mode auto-fills a fake token)
# DISCORD_BOT_TOKEN=your_bot_token_here

# ════════════════════════════════════════════════════════════════════════════
# Email 测试配置（使用真实邮箱）
# ════════════════════════════════════════════════════════════════════════════
#
# 测试流程：
#   1. 配置以下环境变量
#   2. 启动测试，octos 会连接 IMAP 轮询收取邮件
#   3. 向 bot 邮箱发送一封邮件，octos 会自动回复
#
# ── QQ 邮箱配置 ───────────────────────────────────────────────────────────
#   登录 mail.qq.com → 设置 → 账户
#   → 开启 IMAP/SMTP 服务 → 生成授权码（16位字母，不是QQ密码）
#   IMAP: imap.qq.com:993 (SSL)
#   SMTP: smtp.qq.com:465 (SSL)
#
# ── 163 邮箱配置 ──────────────────────────────────────────────────────────
#   登录 mail.163.com → 设置 → POP3/SMTP/IMAP
#   → 开启 IMAP/SMTP → 设置授权码
#   IMAP: imap.163.com:993 (SSL)
#   SMTP: smtp.163.com:465 (SSL)
#
# 启用真实邮箱模式（去掉下面这行的 # 号）
# EMAIL_REAL_TEST=true
#
# Bot 邮箱地址（去掉 # 并替换为你的邮箱）
# EMAIL_USERNAME=your_bot@qq.com      # QQ邮箱示例
# EMAIL_USERNAME=your_bot@163.com     # 163邮箱示例
#
# 邮箱授权码（去掉 # 并替换为你的授权码）
# EMAIL_PASSWORD=your_authorization_code
#
# 自定义 IMAP/SMTP 服务器（可选，默认 QQ 邮箱）
# EMAIL_IMAP_HOST=imap.qq.com         # QQ邮箱无需修改
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.qq.com
# EMAIL_SMTP_PORT=465
